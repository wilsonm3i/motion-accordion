{
  "name": "motion-accordion",
  "version": "0.1.0",
  "description": "A polished React accordion with built-in motion, default styles, and reduced-motion support.",
  "author": "wilsonmei",
  "license": "MIT",
  "type": "module",
  "publishConfig": {
    "access": "public"
  },
  "homepage": "https://github.com/wilsonm3i/motion-accordion#readme",
  "bugs": {
    "url": "https://github.com/wilsonm3i/motion-accordion/issues"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "sideEffects": [
    "**/*.css"
  ],
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "style": "./dist/index.css",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./styles.css": "./dist/index.css",
    "./package.json": "./package.json"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/wilsonm3i/motion-accordion.git"
  },
  "keywords": [
    "react",
    "accordion",
    "animation",
    "framer-motion",
    "component-library"
  ],
  "peerDependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "dependencies": {
    "@base-ui/react": "^1.2.0",
    "framer-motion": "^12.35.2"
  },
  "scripts": {
    "prepare": "pnpm build",
    "dev": "vite build --watch",
    "build": "vite build",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "test": "vitest run --config vitest.config.ts"
  }
}
